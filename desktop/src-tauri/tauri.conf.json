{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Poppy",
  "version": "0.1.0",
  "identifier": "com.george.poppy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Poppy",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "center": true
      },
      {
        "label": "quick",
        "title": "Poppy 文献快问",
        "url": "index.html?window=quick",
        "width": 480,
        "height": 540,
        "minWidth": 360,
        "minHeight": 300,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "contentTypes": ["com.adobe.pdf"],
        "name": "PDF 文献",
        "description": "在 Poppy 中阅读 PDF 文献",
        "role": "Viewer",
        "mimeType": "application/pdf",
        "rank": "Alternate"
      }
    ],
    "externalBin": ["binaries/poppy-gateway"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
