# Copy this file to .env and fill only the providers you use.

# Recommended default. DeepSeek uses its Anthropic-compatible endpoint.
POPPY_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
POPPY_DEEPSEEK_API_KEY=
POPPY_DEEPSEEK_MODEL=deepseek-v4-pro

# Optional right.codes shared key. Used by --provider openai and --provider anthropic when provider-specific keys are empty.
POPPY_RIGHT_CODES_API_KEY=

# Default OpenAI-compatible endpoint. Change this if you use another /responses-compatible service.
POPPY_OPENAI_API_BASE=https://www.right.codes/codex/v1
POPPY_OPENAI_API_KEY=
POPPY_OPENAI_MODEL=gpt-5.4

# Default Anthropic-compatible endpoint. Can reuse POPPY_RIGHT_CODES_API_KEY when your gateway shares one key.
POPPY_ANTHROPIC_API_BASE=https://www.right.codes/claude/v1
POPPY_ANTHROPIC_API_KEY=
POPPY_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional comma-separated extra env names to redact from traces and reports.
POPPY_SECRET_ENV_NAMES=
